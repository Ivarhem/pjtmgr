# ===== 필수 =====
# 운영 환경 구분 (dev / production)
ENV=production

# 세션 시크릿 키 (production 필수, 고정값 사용 — 재시작 시 세션 유지)
# python -c "import secrets; print(secrets.token_hex(32))" 로 생성
SESSION_SECRET_KEY=

# PostgreSQL 비밀번호 (docker-compose에서 DB 생성 시 사용)
POSTGRES_PASSWORD=

# ===== 초기 관리자 (최초 실행 시 1회) =====
BOOTSTRAP_ADMIN_LOGIN_ID=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=관리자

# ===== 선택 =====
# PostgreSQL 접속 URL (기본값: postgresql://pjtmgr:pjtmgr@localhost:5432/pjtmgr)
# Docker 환경에서는 docker-compose.yml이 자동 구성
# DATABASE_URL=postgresql://pjtmgr:pjtmgr@localhost:5432/pjtmgr

# 앱 포트 (기본값: 9000)
# APP_PORT=9000

# 활성화할 모듈 (기본값: common,accounting,infra)
# ENABLED_MODULES=common,accounting,infra

# 카탈로그 연구 백엔드 (기본값: service)
# service: 별도 catalog-research-service 호출
# http: 앱이 Anthropic API 직접 호출
# mcp: mcporter를 통한 MCP 호출
# CATALOG_RESEARCH_BACKEND=service
# CATALOG_RESEARCH_MODEL=claude-sonnet-4-5
# CATALOG_RESEARCH_SERVICE_URL=https://ivarhem.asuscomm.com/apps/catalog-research
# CATALOG_RESEARCH_SERVICE_TOKEN=
# 별도 service 내부 provider 선택: anthropic | codex
# CATALOG_RESEARCH_PROVIDER=anthropic
# CATALOG_RESEARCH_CODEX_BIN=codex
# CATALOG_RESEARCH_CODEX_MODEL=gpt-5.4
# CATALOG_RESEARCH_CODEX_WORKDIR=/tmp
# CATALOG_RESEARCH_CODEX_TIMEOUT=90
# ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=
# CATALOG_RESEARCH_MCP_SERVER=catalog-research
# CATALOG_RESEARCH_MCP_TOOL=lookup_hardware
# CATALOG_RESEARCH_MCP_CONFIG=/app/config/mcporter.json
# CATALOG_RESEARCH_MCPORTER_BIN=mcporter

# 세션 설정
# SESSION_COOKIE_NAME=sales_session
# SESSION_MAX_AGE=28800
# SESSION_SAME_SITE=lax
# SESSION_HTTPS_ONLY=true

# 비밀번호 정책
# PASSWORD_MIN_LENGTH=8

# 로그인 잠금
# LOGIN_MAX_FAILURES=5
# LOGIN_LOCKOUT_SECONDS=900

# 기본 홈 페이지
# DEFAULT_HOME=/my-contracts

# 관리자 계약 신규등록 버튼 (운영 시 false 권장)
# ENABLE_ADMIN_CONTRACT_CREATE=false
